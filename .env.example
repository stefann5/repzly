# Copy this file to .env and fill in your values
# docker-compose will automatically load .env from the same directory

# Shared secret for JWT tokens (must be same across all services)
JWT_SECRET=your-jwt-secret-here

# PostgreSQL (for auth-service)
POSTGRES_PASSWORD=admin

# MongoDB Atlas connection string (for program, started-program, analytics services)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=yourapp

# AWS S3 Configuration (for program-service image uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-central-1
S3_BUCKET_NAME=your-s3-bucket-name

# SMTP Configuration (for auth-service email verification)
SMTP_HOST=smtp.gmail.com
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com

# Application URL (used in verification email links)
APP_URL=http://localhost:3000
